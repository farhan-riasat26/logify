{
  "log_level": "INFO",

  "output": {
    "log_to_console": false,
    "log_to_file": true,
    "json_format": true
  },

  "rotation": {
    "enabled": true,
    "max_bytes": 10485760,
    "backup_count": 5
  },

  "async": {
    "queue_handler": true
  },

  "request_response": {
    "log_request": false,
    "log_response": true,
    "log_headers": false,
    "log_query_params": true,
    "log_path_params": true,
    "log_request_body": false,
    "log_response_body": false,
    "max_body_bytes": 10000,
    "log_method": true,
    "log_url": true,
    "log_status_code": true,
    "log_duration_ms": true,
    "log_client_ip": false,
    "log_user_agent": false
  },

  "transaction": {
    "transaction_log": true,
    "include_request_id": true
  },

  "exception": {
    "include_traceback": true
  },

  "security": {
    "sanitize_sensitive_fields": true,
    "sensitive_keys": [
      "password",
      "token",
      "secret",
      "authorization",
      "api_key",
      "credit_card",
      "ssn",
      "cookie"
    ],
    "redact_replacement": "***REDACTED***"
  },

  "context": {
    "include_hostname": false,
    "include_pid": false,
    "include_app_name": true,
    "app_name": "fastapi-app"
  }
}
